NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — transactional email (password reset, etc.)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM="Zota Corp <onboarding@resend.dev>"

# Fonnte — Indonesia-local WhatsApp gateway for admin attendance alerts.
# Token is per-device; create at https://fonnte.com after scanning the
# sender number's QR. Recipients are comma-separated E.164-without-plus.
FONNTE_TOKEN=your_fonnte_device_token
ADMIN_WA_NUMBERS=628123456789,628987654321

# Protects the daily cron endpoint (/api/cron/sync-cash-sheets) so
# only Vercel's scheduler can trigger it. Generate any random string,
# then set the SAME value in Vercel Project Settings → Environment
# Variables. If unset, the endpoint is open (dev convenience).
CRON_SECRET=

# Office geofences are now managed in-app via Admin → Locations
# (table: attendance_locations). No env var needed.

# LiveKit Cloud — voice channels (/suara). Create a project at
# https://cloud.livekit.io, then copy API key/secret + WS URL.
# Without these, /suara renders a "feature not configured" notice.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_WS_URL=

# Web Push (VAPID) — browser/PWA push notifications. Generate a keypair with
# `npx web-push generate-vapid-keys`. PUBLIC is sent to the browser; PRIVATE
# is server-only. Set all three in Vercel for production.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Stock opname status API (Yeobo Space) — gates employee clock-out (absen
# pulang): studio staff cannot clock out until their branch's stock opname
# is submitted for the day. Server-only; NEVER expose to the client. Set the
# SAME value as in the yeobospace Vercel project. Read in
# src/lib/attendance/stock-opname-gate.ts. If unset, verification fails and
# (fail-closed) clock-out is blocked with a "hubungi admin" message.
STOCK_STATUS_API_KEY=
