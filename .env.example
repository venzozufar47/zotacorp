NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — transactional email (password reset, etc.)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM="Zota Corp <onboarding@resend.dev>"

# Fonnte — Indonesia-local WhatsApp gateway for admin attendance alerts.
# Token is per-device; create at https://fonnte.com after scanning the
# sender number's QR. Recipients are comma-separated E.164-without-plus.
FONNTE_TOKEN=your_fonnte_device_token
ADMIN_WA_NUMBERS=628123456789,628987654321

# Office geofences are now managed in-app via Admin → Locations
# (table: attendance_locations). No env var needed.
